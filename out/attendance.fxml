<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="attendance.AttendanceController"
      spacing="0" style="-fx-background-color: #1a1a2e;">

    <!-- Header -->
    <HBox style="-fx-background-color: #16213e; -fx-padding: 16 28; -fx-alignment: center-left; -fx-spacing: 12;">
        <Label text="📋" style="-fx-font-size: 26px;"/>
        <VBox spacing="2">
            <Label text="Smart Attendance System"
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e2e8f0;"/>
            <Label text="COMP1402 — Object Oriented Programming"
                   style="-fx-font-size: 11px; -fx-text-fill: #718096;"/>
        </VBox>
    </HBox>

    <!-- Tab Pane -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
             style="-fx-background-color: #1a1a2e; -fx-tab-min-width: 140px;">

        <!-- ═══════════════════════════════════════════════════════
             TAB 1 — Attendance
             ═══════════════════════════════════════════════════════ -->
        <Tab text="📝  Attendance">
            <HBox spacing="0" VBox.vgrow="ALWAYS">

                <!-- Left Panel -->
                <VBox spacing="14" style="-fx-background-color: #16213e; -fx-padding: 22; -fx-min-width: 270; -fx-max-width: 270;">

                    <Label text="Log Attendance"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>

                    <!-- Name -->
                    <VBox spacing="5">
                        <Label text="Student Name" style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <TextField fx:id="nameField" promptText="e.g. Budi Santoso"
                                   style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #4a5568; -fx-border-color: #2d3748;
                                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;"/>
                    </VBox>

                    <!-- ID -->
                    <VBox spacing="5">
                        <Label text="Student ID" style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <TextField fx:id="idField" promptText="e.g. 2024001"
                                   style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #4a5568; -fx-border-color: #2d3748;
                                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;"/>
                    </VBox>

                    <!-- Subject -->
                    <VBox spacing="5">
                        <Label text="Subject" style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <ComboBox fx:id="subjectCombo" maxWidth="Infinity"
                                  promptText="Select subject..."
                                  style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;"/>
                    </VBox>

                    <!-- Status -->
                    <VBox spacing="6">
                        <Label text="Status" style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <HBox spacing="16">
                            <RadioButton fx:id="presentRadio" text="Present"
                                         style="-fx-text-fill: #68d391;">
                                <toggleGroup><ToggleGroup fx:id="statusGroup"/></toggleGroup>
                            </RadioButton>
                            <RadioButton fx:id="absentRadio" text="Absent"
                                         toggleGroup="$statusGroup"
                                         style="-fx-text-fill: #fc8181;"/>
                        </HBox>
                    </VBox>

                    <!-- Log Button -->
                    <Button text="Log Attendance →" onAction="#handleLogAttendance"
                            maxWidth="Infinity"
                            style="-fx-background-color: #0ea5e9; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 9 14;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Separator style="-fx-background-color: #2d3748;"/>

                    <!-- Export -->
                    <Button text="📄  Export Report (HTML→PDF)" onAction="#handleExportReport"
                            maxWidth="Infinity"
                            style="-fx-background-color: #1a6e3e; -fx-text-fill: #68d391;
                                   -fx-font-size: 12px; -fx-padding: 8 14;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button text="↻  Refresh" onAction="#handleRefresh"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2d3748; -fx-text-fill: #a0aec0;
                                   -fx-font-size: 12px; -fx-padding: 8 14;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button text="🗑  Clear All Records" onAction="#handleClearAll"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2d3748; -fx-text-fill: #fc8181;
                                   -fx-font-size: 12px; -fx-padding: 8 14;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <VBox VBox.vgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text="" wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #68d391;"/>
                    <Label fx:id="filePathLabel" text="" wrapText="true"
                           style="-fx-font-size: 10px; -fx-text-fill: #4a5568;"/>
                </VBox>

                <!-- Right Panel -->
                <VBox spacing="10" style="-fx-padding: 22;" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">

                    <!-- Search bar + totals -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="🔍 Search by name or ID..."
                                   prefWidth="260"
                                   style="-fx-background-color: #16213e; -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #4a5568; -fx-border-color: #2d3748;
                                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;"/>
                        <Label fx:id="totalLabel" text="Showing: 0"
                               style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                    </HBox>

                    <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #16213e; -fx-border-color: #2d3748;
                                      -fx-border-radius: 8; -fx-background-radius: 8;">
                        <columns>
                            <TableColumn fx:id="nameColumn"      text="Student Name" prefWidth="160"/>
                            <TableColumn fx:id="idColumn"        text="Student ID"   prefWidth="100"/>
                            <TableColumn fx:id="subjectColumn"   text="Subject"      prefWidth="130"/>
                            <TableColumn fx:id="statusColumn"    text="Status"       prefWidth="85"/>
                            <TableColumn fx:id="timestampColumn" text="Timestamp"    prefWidth="165"/>
                        </columns>
                        <placeholder>
                            <Label text="No records yet. Log your first attendance."
                                   style="-fx-text-fill: #4a5568;"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>

        <!-- ═══════════════════════════════════════════════════════
             TAB 2 — Students
             ═══════════════════════════════════════════════════════ -->
        <Tab text="👤  Students">
            <HBox spacing="0">

                <!-- Left Panel -->
                <VBox spacing="14" style="-fx-background-color: #16213e; -fx-padding: 22; -fx-min-width: 270; -fx-max-width: 270;">

                    <Label text="Add / Edit Student"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>

                    <VBox spacing="5">
                        <Label text="Full Name" style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <TextField fx:id="stuNameField" promptText="e.g. Rina Putri"
                                   style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #4a5568; -fx-border-color: #2d3748;
                                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Student ID" style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <TextField fx:id="stuIdField" promptText="e.g. 2024002"
                                   style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #4a5568; -fx-border-color: #2d3748;
                                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Subjects (comma-separated)"
                               style="-fx-text-fill: #cbd5e0; -fx-font-size: 11px;"/>
                        <TextField fx:id="stuSubjectField" promptText="e.g. COMP1402, MATH1101"
                                   style="-fx-background-color: #0f3460; -fx-text-fill: #e2e8f0;
                                          -fx-prompt-text-fill: #4a5568; -fx-border-color: #2d3748;
                                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 7 10;"/>
                    </VBox>

                    <Button text="💾  Save Student" onAction="#handleAddStudent"
                            maxWidth="Infinity"
                            style="-fx-background-color: #0ea5e9; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-padding: 9 14;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <Button text="🗑  Delete Selected" onAction="#handleDeleteStudent"
                            maxWidth="Infinity"
                            style="-fx-background-color: #2d3748; -fx-text-fill: #fc8181;
                                   -fx-font-size: 12px; -fx-padding: 8 14;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>

                    <VBox VBox.vgrow="ALWAYS"/>
                    <Label fx:id="stuStatusLabel" text="" wrapText="true"
                           style="-fx-font-size: 11px; -fx-text-fill: #68d391;"/>
                </VBox>

                <!-- Right Panel -->
                <VBox spacing="10" style="-fx-padding: 22;" VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS">
                    <Label text="Student Roster"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #a0aec0;"/>

                    <TableView fx:id="studentTable" VBox.vgrow="ALWAYS"
                               onMouseClicked="#handleStudentTableClick"
                               style="-fx-background-color: #16213e; -fx-border-color: #2d3748;
                                      -fx-border-radius: 8; -fx-background-radius: 8;">
                        <columns>
                            <TableColumn fx:id="stuIdColumn"       text="Student ID" prefWidth="120"/>
                            <TableColumn fx:id="stuNameColumn"     text="Name"       prefWidth="180"/>
                            <TableColumn fx:id="stuSubjectsColumn" text="Subjects"   prefWidth="300"/>
                        </columns>
                        <placeholder>
                            <Label text="No students yet. Add one on the left."
                                   style="-fx-text-fill: #4a5568;"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </HBox>
        </Tab>

    </TabPane>
</VBox>
